# ===========================
# Kupon Merkezi - Environment Variables
# ===========================

# App
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/kupon_merkezi?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=KuponMerkeziBot

# OpenAI (for Vision API / OCR)
OPENAI_API_KEY=your-openai-api-key

# API-Football (RapidAPI)
API_FOOTBALL_KEY=your-api-football-key
API_FOOTBALL_HOST=v3.football.api-sports.io

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
